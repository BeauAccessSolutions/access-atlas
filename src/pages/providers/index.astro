---
// On-demand so newly submitted providers appear immediately. Zero-JS.
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getListings } from '../../lib/repo';

const providers = await getListings('provider');
---

<Base
  title="Providers"
  description="Disability-competent and disabled-owned or disabled-led providers."
>
  <h1>Providers</h1>
  <p>
    Two things matter here, tracked separately: whether a provider is
    <strong>disability-literate</strong> (serves disabled people well) and
    whether they are <strong>disabled-owned or disabled-led</strong>. A provider
    may be either, both, or neither — we never merge the two.
  </p>
  <p><a href="/contribute/submit/?kind=provider">+ Suggest a provider</a></p>

  {
    providers.length === 0 ? (
      <div class="disclaimer">
        <p>
          <strong>No providers here yet.</strong> We're seeding Buffalo / Erie
          County first, and listings are validated by first-person visits — so
          coverage starts thin and grows as people contribute.
        </p>
        <p>
          <a href="/contribute/submit/?kind=provider">Suggest a provider</a>, or
          browse <a href="/places/">places</a> instead.
        </p>
      </div>
    ) : (
      <ul class="listing-list">
        {providers.map((listing) => (
          <ListingCard listing={listing} />
        ))}
      </ul>
    )
  }
</Base>
