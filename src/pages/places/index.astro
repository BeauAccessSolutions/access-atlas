---
import Base from '../../layouts/Base.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getListings } from '../../lib/repo';

const places = await getListings('place');
---

<Base title="Places" description="Accessible businesses and physical spaces.">
  <h1>Accessible places</h1>
  <p>
    {places.length} {places.length === 1 ? 'place' : 'places'} listed. This list
    is the primary interface — no map required. (A map may be added later as a
    progressive enhancement over this same list.)
  </p>

  {
    places.length === 0 ? (
      <p>No places listed yet.</p>
    ) : (
      <ul class="listing-list">
        {places.map((listing) => (
          <ListingCard listing={listing} />
        ))}
      </ul>
    )
  }
</Base>
